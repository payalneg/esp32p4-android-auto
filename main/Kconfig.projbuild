menu "Android Auto Head Unit"

    choice AA_WIFI_ROLE
        prompt "WiFi role"
        default AA_WIFI_ROLE_AP
        help
            Real Android Auto head units run as the WiFi access point
            (the phone joins the head unit's network). STA mode is only
            useful for bench testing where both devices share an
            existing WiFi network.

        config AA_WIFI_ROLE_AP
            bool "SoftAP (production)"

        config AA_WIFI_ROLE_STA
            bool "Station — connect to existing WiFi (bench test only)"
    endchoice

    config AA_AP_SSID_PREFIX
        string "AP SSID prefix"
        depends on AA_WIFI_ROLE_AP
        default "AAHU"
        help
            Last 4 hex digits of the MAC are appended, e.g. "AAHU-1A2B".

    config AA_AP_PASSWORD
        string "AP password (WPA2-PSK, min 8 chars)"
        depends on AA_WIFI_ROLE_AP
        default "12345678"

    config AA_AP_CHANNEL
        int "AP channel (1-13)"
        depends on AA_WIFI_ROLE_AP
        default 6
        range 1 13

    config AA_WIFI_SSID
        string "Bench WiFi SSID"
        depends on AA_WIFI_ROLE_STA
        default "myssid"

    config AA_WIFI_PASSWORD
        string "Bench WiFi password"
        depends on AA_WIFI_ROLE_STA
        default "mypassword"

    config AA_WIFI_MAX_RETRY
        int "Maximum STA connect retries"
        depends on AA_WIFI_ROLE_STA
        default 10

    config AA_OVERCLOCK_400
        bool "Overclock CPU to 400 MHz (unsupported on rev <3.0)"
        default n
        help
            ESP32-P4 silicon ≤ rev 1.x is officially capped at 360 MHz in
            ESP-IDF. The CPLL is physically capable of 400 MHz on most
            engineering samples but Espressif provides no guarantees.
            With this option enabled, app_main reprograms CPLL to 400 MHz
            and switches CPU divider to 1 right after NVS init.
            Disable this if the chip becomes unstable or refuses to boot.

    menu "BT Agent OTA (Mode A)"

        config BT_AGENT_OTA_ENABLED
            bool "Reflash BT agent on version mismatch"
            default n
            help
                On boot, parse the agent's BT-VER:<version> line and compare
                to BT_AGENT_FW_VERSION below. On mismatch, force the D1 Mini
                into ROM bootloader (via GPIO24/25) and reflash from the
                binary embedded at components/bt_agent_fw/bt_agent_fw.bin.
                Uses the espressif/esp_serial_flasher managed component.

                Build will fail with a clear error if enabled without the
                binary present. To disable OTA without removing the binary,
                just keep this option n.

        config BT_AGENT_FW_VERSION
            string "Expected BT agent firmware version"
            depends on BT_AGENT_OTA_ENABLED
            default "0.3.0"
            help
                Must exactly match what the agent emits on boot via
                `BT-VER:<version>`. Bump this in lockstep with the agent
                firmware build. If the agent reports a different value
                (or no value within BT_AGENT_VERSION_TIMEOUT_MS), OTA fires.

        config BT_AGENT_VERSION_TIMEOUT_MS
            int "Timeout waiting for BT-VER: line (ms)"
            depends on BT_AGENT_OTA_ENABLED
            default 3000
            range 500 30000
            help
                If the agent doesn't emit a BT-VER: line within this window
                after bt_link_init's reset, treat it as a missing/broken
                firmware and trigger OTA. Bump if the agent's app is slow
                to start (NVS scan, sensor init, etc.).

        config BT_AGENT_FLASH_BAUD
            int "Flasher baud rate during OTA"
            depends on BT_AGENT_OTA_ENABLED
            default 460800
            help
                ROM/stub bootloader sync is always at 115200, then renegotiates
                up to this rate for the actual write. 460800 over short
                direct UART wires is the usual sweet spot; 921600 also
                works but cuts error margin. Drop to 115200 if you suspect
                signal-integrity issues on a long noisy line.

    endmenu

    menu "OTA over WiFi"

        config OTA_HTTP_ENABLED
            bool "Enable HTTP OTA server"
            default y
            help
                Starts a small HTTP server (default port 80) on the SoftAP
                interface after WiFi is up. POST the new app binary to
                /ota and the device will flash the inactive OTA slot and
                reboot. See scripts/ota_push.sh.

        config OTA_HTTP_PORT
            int "OTA HTTP port"
            depends on OTA_HTTP_ENABLED
            default 80
            range 1 65535

    endmenu

endmenu
